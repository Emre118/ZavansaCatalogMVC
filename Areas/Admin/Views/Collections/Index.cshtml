@model IEnumerable<ProductCollection>
@{
    ViewData["Title"] = "Koleksiyonlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Koleksiyonlar</h1>
    <a class="btn btn-zavansa" asp-action="Create">Yeni Koleksiyon</a>
</div>

<div class="card">
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Görsel</th><th>Sıra</th><th>Ad</th><th>Açıklama</th><th>Aktif</th><th class="text-end">İşlemler</th></tr></thead>
        <tbody>
            @foreach (var collection in Model)
            {
                var collectionImageUrl = string.IsNullOrWhiteSpace(collection.ImageUrl) ? "/images/placeholders/product-placeholder.svg" : collection.ImageUrl;
                <tr>
                    <td><img class="thumb" src="@collectionImageUrl" alt="@collection.Name" onerror="this.onerror=null;this.src='/images/placeholders/product-placeholder.svg';" /></td>
                    <td>@collection.DisplayOrder</td>
                    <td>@collection.Name</td>
                    <td>@collection.Description</td>
                    <td>@(collection.IsActive ? "Evet" : "Hayır")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@collection.Id">Detay</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@collection.Id">Düzenle</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@collection.Id">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
