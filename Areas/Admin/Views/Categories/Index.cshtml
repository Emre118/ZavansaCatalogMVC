@model IEnumerable<Category>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Kategoriler</h1>
    <a class="btn btn-zavansa" asp-action="Create">Yeni Kategori</a>
</div>

<div class="card">
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Ad</th><th>Açıklama</th><th>Aktif</th><th class="text-end">İşlemler</th></tr></thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.Description</td>
                    <td>@(category.IsActive ? "Evet" : "Hayır")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@category.Id">Detay</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@category.Id">Düzenle</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@category.Id">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
