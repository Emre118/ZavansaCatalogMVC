<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zavansa Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid admin-layout">
        <div class="row">
            <aside class="col-md-3 col-xl-2 admin-sidebar p-3">
                <h5 class="text-white mb-4">Zavansa Admin</h5>
                <nav class="d-grid gap-1">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index">Ürünler</a>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index">Kategoriler</a>
                    <a asp-area="Admin" asp-controller="Collections" asp-action="Index">Koleksiyonlar</a>
                    <a asp-area="Admin" asp-controller="Messages" asp-action="Index">Mesajlar</a>
                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index">Site Ayarları</a>
                    <a asp-area="Admin" asp-controller="Account" asp-action="Logout">Çıkış</a>
                    <a asp-area="" asp-controller="Home" asp-action="Index">Siteye Dön</a>
                </nav>
            </aside>
            <main class="col-md-9 col-xl-10 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
