@model ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Mesaj Detayı</h1>
    <a asp-action="Index" class="btn btn-outline-dark">Listeye Dön</a>
</div>

<div class="card card-body mb-3">
    <dl class="row">
        <dt class="col-sm-3">Gönderen</dt><dd class="col-sm-9">@Model.FullName</dd>
        <dt class="col-sm-3">E-posta</dt><dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Telefon</dt><dd class="col-sm-9">@(Model.Phone ?? "-")</dd>
        <dt class="col-sm-3">Konu</dt><dd class="col-sm-9">@(Model.Subject ?? "-")</dd>
        <dt class="col-sm-3">İlgilenilen Ürün</dt><dd class="col-sm-9">@(Model.InterestedProductName ?? Model.Product?.Name ?? "-")</dd>
        <dt class="col-sm-3">Durum</dt><dd class="col-sm-9">@Model.Status</dd>
        <dt class="col-sm-3">Tarih</dt><dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        <dt class="col-sm-3">Mesaj</dt><dd class="col-sm-9">@Model.Message</dd>
    </dl>
</div>

<div class="d-flex flex-wrap gap-2">
    <form asp-action="MarkAsRead" asp-route-id="@Model.Id" method="post">
        <button class="btn btn-outline-primary" type="submit">Okundu İşaretle</button>
    </form>
    <form asp-action="MarkAsReplied" asp-route-id="@Model.Id" method="post">
        <button class="btn btn-outline-success" type="submit">Cevaplandı İşaretle</button>
    </form>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Sil</a>
</div>
