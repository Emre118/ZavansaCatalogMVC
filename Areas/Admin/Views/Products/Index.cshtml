@model IEnumerable<Product>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Ürünler</h1>
    <a class="btn btn-zavansa" asp-action="Create">Yeni Ürün</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Ürün</th>
                    <th>Kategori</th>
                    <th>Koleksiyon</th>
                    <th>Aktif</th>
                    <th>Öne Çıkan</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    var productImageUrl = string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/placeholders/product-placeholder.svg" : product.ImageUrl;
                    <tr>
                        <td><img class="thumb" src="@productImageUrl" alt="@product.Name" onerror="this.onerror=null;this.src='/images/placeholders/product-placeholder.svg';" /></td>
                        <td>@product.Name</td>
                        <td>@product.Category?.Name</td>
                        <td>@product.ProductCollection?.Name</td>
                        <td>@(product.IsActive ? "Evet" : "Hayır")</td>
                        <td>@(product.IsFeatured ? "Evet" : "Hayır")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-dark" asp-action="Details" asp-route-id="@product.Id">Detay</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@product.Id">Düzenle</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.Id">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
