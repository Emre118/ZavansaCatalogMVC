<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zavansa Aydınlatma ve Dekor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-zavansa sticky-top">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Zavansa</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Ürünler</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Collections" asp-action="Index">Koleksiyonlar</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Catalog" asp-action="Index">Katalog</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Hakkımızda</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Contact" asp-action="Index">İletişim</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success">@TempData["Success"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer py-4 mt-5">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>© @DateTime.Now.Year Zavansa Aydınlatma ve Dekor</span>
            <span>Ürün katalog sitesi - Sepet, ödeme ve kargo işlemleri içermez.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
