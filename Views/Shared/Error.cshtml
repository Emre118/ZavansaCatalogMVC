@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<section class="container py-5">
    <h1>Bir hata oluştu</h1>
    <p class="text-muted">İşlem sırasında beklenmeyen bir sorun yaşandı.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">İstek No: @Model.RequestId</p>
    }
</section>
